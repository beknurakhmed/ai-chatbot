# Backend environment variables
# These can be overridden in docker-compose.yml

# Optional: Anthropic API key for Claude integration
# ANTHROPIC_API_KEY=your_key_here

# ========================================
# LLM CONFIGURATION (6GB VRAM OPTIMIZED)
# ========================================
# For 6GB VRAM: use qwen2.5:3b-instruct (≈2.5-3GB) instead of qwen2.5:7b (≈5-6GB)
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_HOST=http://ollama:11434

# Legacy alternative:
# LOCAL_LLM_URL=http://localhost:1234
# LOCAL_LLM_MODEL=local-model

# ========================================
# STT (SPEECH-TO-TEXT) CONFIGURATION
# ========================================
# Default: auto (auto-detects VRAM, falls back to CPU if <1.5GB free)
# Override if needed: WHISPER_DEVICE=cpu | cuda | auto
# - CPU: slower but saves VRAM, works on any system
# - CUDA: faster, requires sufficient VRAM
# - auto: (recommended) smart detection based on available VRAM
#
# Whisper model size (for local STT): tiny, base (default), small, medium, large-v2, large-v3
WHISPER_DEVICE=auto
WHISPER_MODEL=base

# ========================================
# TTS (TEXT-TO-SPEECH) CONFIGURATION
# ========================================
# Automatic: Silero TTS for uz/ru/en (local), edge-tts fallback for kr
# Silero auto-detects CUDA and falls back to CPU if needed
# No special configuration required

# Optional: Hugging Face token for faster model downloads
# HF_TOKEN=your_hf_token_here

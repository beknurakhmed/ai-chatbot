# Kiosk Sleep Mode Configuration (SNA - Static No Activity)
# Если true - режим сна включен
NEXT_PUBLIC_KIOSK_SLEEP_MODE_ENABLED=false
# Время бездействия до сна (мс)
NEXT_PUBLIC_KIOSK_IDLE_TIMEOUT=20000
# Порог обнаружения лица для пробуждения (количество успешных детекций)
NEXT_PUBLIC_KIOSK_WAKE_THRESHOLD=3
# Разрешить сон только в определённые часы (0-23). Если не задано - без ограничений.
# NEXT_PUBLIC_KIOSK_SLEEP_ALLOWED_START_HOUR=22
# NEXT_PUBLIC_KIOSK_SLEEP_ALLOWED_END_HOUR=6

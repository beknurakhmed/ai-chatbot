# Backend API URL (change to your domain in production)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Languages to show (comma-separated: uz,ru,en,kr)
NEXT_PUBLIC_LANGUAGES=en

# Kiosk Sleep Mode
NEXT_PUBLIC_KIOSK_SLEEP_MODE_ENABLED=false
NEXT_PUBLIC_KIOSK_IDLE_TIMEOUT=10000
NEXT_PUBLIC_KIOSK_WAKE_THRESHOLD=3
